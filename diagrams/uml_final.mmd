classDiagram
    class PetOwner {
        +str name
        +str[] preferences
        +Pet[] pets
        +add_pet(pet) void
        +update_preferences(preferences) void
        +get_all_tasks() tuple[]
        +get_tasks_for_pet(pet_name) Task[]
    }

    class Pet {
        +str name
        +str species
        +int age
        +Task[] tasks
        +add_task(task) void
        +remove_completed_tasks() void
        +get_tasks() Task[]
    }

    class Task {
        +str description
        +int duration_minutes
        +str priority
        +str time_of_day
        +str category
        +str frequency
        +bool completed
        +mark_complete() void
        +next_occurrence() Task
    }

    class Scheduler {
        +PetOwner owner
        +int available_minutes
        +str start_time
        +sort_by_time(tasks) tuple[]
        +filter_tasks(tasks, pet_name, completed) tuple[]
        +detect_conflicts(tasks) str[]
        +sort_tasks(tasks) tuple[]
        +build_daily_schedule() dict[]
        +explain_plan(tasks) str[]
    }

    PetOwner "1" o-- "many" Pet : owns
    Pet "1" o-- "many" Task : has
    Scheduler --> PetOwner : plans for