classDiagram
    class PetOwner {
        +str name
        +str[] preferences
        +Pet[] pets
        +add_pet(pet) void
        +update_preferences(preferences) void
    }

    class Pet {
        +str name
        +str species
        +int age
        +Task[] tasks
        +add_task(task) void
        +get_tasks() Task[]
    }

    class Task {
        +str title
        +int duration_minutes
        +str priority
        +str category
        +bool recurring
    }

    class Scheduler {
        +PetOwner owner
        +Pet pet
        +int available_minutes
        +build_daily_plan() Task[]
        +sort_tasks(tasks) Task[]
        +explain_plan(tasks) str[]
    }

    PetOwner "1" o-- "many" Pet : owns
    Pet "1" o-- "many" Task : has
    Scheduler --> Pet : plans for
    Scheduler --> PetOwner : plans for
